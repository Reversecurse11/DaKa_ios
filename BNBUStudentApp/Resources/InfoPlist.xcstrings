    "NSCameraUsageDescription" : {
      "comment" : "Privacy - Camera Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The camera is used only when you choose to capture check-in or exemption evidence."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仅在您选择拍摄体育打卡或免测凭证时使用摄像头。"
          }
        }
      }
    },
    "NSLocalNetworkUsageDescription" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The local network is used only to connect to the BNBU sports check-in test server during development."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仅用于开发调试时连接 BNBU 体育打卡测试服务器。"
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location When In Use Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your location is requested once when an exercise starts to help verify the activity. Denying location access does not prevent timing or submission."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仅在开始运动打卡时获取一次位置，用于辅助确认运动真实性；拒绝定位不影响计时和提交。"
          }
        }
      }
    },
    "NSMicrophoneUsageDescription" : {
      "comment" : "Privacy - Microphone Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The microphone is used only when you choose to record video evidence with sound."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仅在您主动录制带声音的视频凭证时使用麦克风。"
          }
        }
      }
    }
  },
  "version" : "1.0"
