      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "First reopen the page or sign in again. Signing out clears this account's local cache, unsubmitted drafts, and pending retry operations."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "先重新进入页面或重新登录。退出登录会清除当前账号的本地缓存、未提交草稿和待重试操作，请谨慎操作。"
          }
